# Reeve environment — copy to .env and fill in. NEVER commit the real .env.

# GitHub personal access token (fine-grained or classic) with access to the
# sandbox repo. Used for every GitHub API call.
GITHUB_TOKEN=

# Google Generative AI API key, read by Mastra's model router (@ai-sdk/google).
GOOGLE_GENERATIVE_AI_API_KEY=

# The repository Reeve operates on, as "owner/repo".
GITHUB_SANDBOX_REPO=owner/repo

# Optional. development | test | production (default: development)
# NODE_ENV=development

# Optional logging controls.
# REEVE_LOG_LEVEL=info        # trace|debug|info|warn|error|fatal
# REEVE_LOG_PRETTY=1          # human-readable logs in dev
